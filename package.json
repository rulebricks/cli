{
  "name": "@rulebricks/cli",
  "version": "2.3.2",
  "description": "CLI for deploying and managing private Rulebricks instances",
  "type": "module",
  "bin": {
    "rulebricks": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "sync-schema": "node scripts/sync-schema.mjs",
    "test": "npm run build && node --test dist/lib/versions.test.js dist/lib/helmValues.test.js dist/lib/dns.test.js dist/lib/workloadIdentity.test.js",
    "verify-chart": "npm run build && node scripts/verify-against-chart.mjs"
  },
  "keywords": [
    "rulebricks",
    "kubernetes",
    "helm",
    "cli",
    "deployment"
  ],
  "author": "Rulebricks",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rulebricks/cli.git"
  },
  "homepage": "https://github.com/rulebricks/cli#readme",
  "bugs": {
    "url": "https://github.com/rulebricks/cli/issues"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^8.0.1",
    "figures": "^6.1.0",
    "ink": "^6.6.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "node-fetch": "^3.3.2",
    "ora": "^8.0.1",
    "react": "^19.2.4",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.4",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "cluster-setup",
    "templates",
    "benchmarks",
    "schema"
  ]
}
